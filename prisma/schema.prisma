generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Vehicle {
  id           Int          @id @default(autoincrement())
  name         String
  brand        String?
  model        String?
  year         Int?
  fuelCategory FuelCategory @default(PETROL)   
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  fillUps      FuelFillUp[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum FuelCategory {
  PETROL
  DIESEL
}

enum FuelType {
  DIESEL
  PETROL_95
  PETROL_100
}

model FuelFillUp {
  id         Int      @id @default(autoincrement())
  date       DateTime
  liters     Float
  totalCost  Float
  odometerKm Float?
  isFullTank Boolean  @default(true)
  fuelType   FuelType @default(PETROL_95)
  createdAt  DateTime @default(now())

  vehicleId Int
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  fillUps       FuelFillUp[]
  vehicles Vehicle[]   

}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
